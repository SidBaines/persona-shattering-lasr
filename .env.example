# Copy this file to .env and fill in your keys.
# Never commit .env itself.

# Hugging Face — required for gated models (e.g. Llama)
HF_TOKEN=your_hf_token_here

# Anthropic — required if editing.provider = "anthropic"
ANTHROPIC_API_KEY=your_anthropic_key_here

# OpenAI — required if editing.provider = "openai"
OPENAI_API_KEY=your_openai_key_here

# Weights & Biases — required if wandb.enabled = true
WANDB_API_KEY=your_wandb_key_here
